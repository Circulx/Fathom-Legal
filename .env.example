# Email Service Configuration (Zoho Mail)
# Copy this file to .env.local and fill in your actual values

# Zoho Email Configuration
ZOHO_EMAIL=your-email@zoho.com
ZOHO_PASSWORD=your-app-password-here
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465

# Optional: Regional Zoho SMTP servers
# For Europe: smtp.zoho.eu
# For India: smtp.zoho.in
# For Japan: smtp.zoho.jp
# For China: smtp.zoho.com.cn
